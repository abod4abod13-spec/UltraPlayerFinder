local msgBtn = Instance.new("TextButton")
msgBtn.Size = UDim2.new(0, 200, 0, 40)
msgBtn.Position = UDim2.new(0, 25, 0, 140)
msgBtn.Text = "Send Message"
msgBtn.Parent = main

msgBtn.MouseButton1Click:Connect(function()
	game.StarterGui:SetCore("ChatMakeSystemMessage", {
		Text = "Hello from Admin Panel!";
